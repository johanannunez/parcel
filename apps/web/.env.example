# ============================================================
# Parcel apps/web — environment variable template
# ============================================================
# Copy this file to .env.local (which is gitignored) and fill
# in real values, OR pull straight from Vercel with:
#
#   vercel env pull apps/web/.env.local --environment development
#
# Source of truth: Doppler project `parcel`, config `prd`.
# Doppler pushes into Vercel; Vercel pushes into .env.local.
# ============================================================


# -----
# Supabase (required)
# -----
# Project: parcel
# Org:     The Parcel Company
# Region:  us-west-1
#
# Dashboard:
#   https://supabase.com/dashboard/project/pwoxwpryummqeqsxdgyc/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://pwoxwpryummqeqsxdgyc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-jwt-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-jwt-here


# -----
# Hospitable (required for live listings + bookings sync)
# -----
# Bearer token (JWT) from the Hospitable developer portal.
# Used by apps/web/src/lib/hospitable.ts to pull the 13 Parcel
# properties, reservations, calendars. Without this the
# marketing /properties page falls back to an empty list.
HOSPITABLE_API=your-hospitable-jwt-here


# -----
# Resend (required for transactional email)
# -----
# Used by the Supabase Auth custom SMTP integration to send
# password resets, magic links, invites, and confirmations
# from hello@theparcelco.com. Also used by the /free-tips form
# and any future owner notifications.
#
# Dashboard:
#   https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-key-here


# -----
# Stripe (required once payouts go live)
# -----
# WARNING: starts as sk_test_... (test mode). Swap to a real
# sk_live_... key before taking real owner or guest payments.
#
# Dashboard:
#   https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_or_sk_live_here


# -----
# Cloudflare (optional, DNS automation)
# -----
# Scoped API token with DNS:Edit on the theparcelco.com zone.
# Currently unused by runtime code; kept available for future
# automation (DKIM record provisioning, preview subdomain
# creation, etc.).
CLOUDFLARE_API_TOKEN=cfut_your-token-here


# -----
# Turno (required for cleaning coordination, future)
# -----
# Turno (formerly TurnoverBnB) API token. Used to sync cleaning
# turnovers with reservations once Hospitable sync is live.
TURNO_API_KEY=eyJ0eXAiOiJKV...


# -----
# Hubflo (optional, CRM / client portal, future)
# -----
# Used for owner CRM data once Parcel grows past manual
# spreadsheets.
HUBFLO_API_KEY=your-hubflo-key


# -----
# Quo (optional, short term rental insurance, future)
# -----
# Quo API key for offering STR-specific liability coverage to
# owners during onboarding.
QUO_API_KEY=your-quo-key


# -----
# Inquiry routing
# -----
# Email address that receives inquiry form submissions from the
# public marketing site contact form.
INQUIRY_TO_EMAIL=hello@theparcelco.com
