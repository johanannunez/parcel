# ============================================================
# Parcel apps/web — environment variable template
# ============================================================
# Copy this file to .env.local (which is gitignored) and fill
# in the real values. For Vercel production and preview
# environments, set these same values in:
#   Vercel Dashboard > Project Settings > Environment Variables
# ============================================================

# -----
# Supabase (required)
# -----
# Project: parcel
# Org:     The Parcel Company
# Region:  us-west-1 (West US, North California)
# Find these at:
#   https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-jwt-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-jwt-here

# -----
# Hospitable (optional, runtime)
# -----
# Only needed if the Hospitable booking widgets on /properties/[slug]
# need to pull real property data at request time. Safe to leave
# unset during development; the widgets will show a fallback.
# HOSPITABLE_API=your-hospitable-api-token
