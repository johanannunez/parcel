{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/hero-options/layout,_N_T_/hero-options/page,_N_T_/hero-options"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/hero-options/__PAGE__",
    "/hero-options",
    "/_index",
    "/_head"
  ]
}